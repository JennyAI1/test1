# ---------- Shared ----------
# Comma-separated origins allowed by backend CORS.
CORS_ORIGINS=http://localhost:3000

# ---------- Backend ----------
APP_NAME=Research Workspace API
JWT_SECRET=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/research_workspace
NOTES_ENCRYPTION_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDABLE_URL_ALLOWLIST=arxiv.org,observablehq.com,docs.google.com,notion.so
BACKEND_PORT=8000
UVICORN_WORKERS=2

# ---------- Postgres ----------
POSTGRES_DB=research_workspace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
